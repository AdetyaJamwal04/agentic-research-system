# Environment Variables Template
# Copy this file to .env and fill in your actual keys

# ===== REQUIRED =====

# Groq API Key (Primary LLM)
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Tavily API Key (Web Search)
# Sign up: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ===== OPTIONAL =====

# Google Gemini API Key (Fallback LLM)
# Sign up: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Debug Mode
DEBUG=false

# ===== DEPLOYMENT-SPECIFIC =====

# For Render, Railway, etc., set as environment variables in the dashboard
# Do NOT commit actual .env with real keys to version control
